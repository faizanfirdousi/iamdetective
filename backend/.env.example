# Server
PORT=8080
GIN_MODE=debug

# Database
DATABASE_URL=postgres://user:password@localhost:5432/iamdetective?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# External APIs
COURTLISTENER_API_TOKEN=your_courtlistener_token
FBI_API_KEY=your_fbi_api_key
INDIANKANOON_API_TOKEN=your_indiankanoon_api_token
ECOURTS_API_TOKEN=eci_live_your_token_here
